{
  "name": "ruralicos-api",
  "version": "1.0.0",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "npm run lint && npm run test:local && npm run check:core",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "audit:high": "npm audit --audit-level=high",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rutas:inventario": "node scripts/inventario_rutas.js",
    "openapi:generar": "node scripts/generar_openapi.js",
    "workflow:digest": "node scripts/run_digest_workflow.js",
    "backfill:intelligence": "node scripts/backfill_alert_intelligence.js",
    "repair:legacy-discards": "node scripts/repair_legacy_alert_discards.js",
    "repair:stale-pipeline-jobs": "node scripts/repair_stale_pipeline_jobs.js",
    "p0:acceptance": "node scripts/p0_acceptance_gate.js",
    "knowledge:ingest": "node scripts/ingest_mia_knowledge.js",
    "check:core": "node scripts/check_core_logic.js",
    "test:local": "node scripts/run_tests.js"
  },
  "dependencies": {
    "@sentry/node": "^10.67.0",
    "@supabase/supabase-js": "^2.110.8",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "fast-xml-parser": "^5.10.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.4"
  }
}
