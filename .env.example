# ─────────────────────────────────────────────
# RURALICOS API — Variables de entorno requeridas
# Copia este archivo a .env y rellena los valores.
# NUNCA subas .env a git.
# ─────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# OpenAI
OPENAI_API_KEY=sk-...
# Las tareas estructuradas con gpt-5-nano usan razonamiento minimo para reservar
# el presupuesto de salida al JSON visible (minimal por defecto).
IA_GPT5_NANO_REASONING_EFFORT=minimal

# Preparacion de digest: una persona por request evita superar el timeout del
# proxy cuando la seleccion requiere varias llamadas IA.
PREPARAR_DIGEST_BATCH_SIZE=1
# Numero maximo de usuarios que el workflow puede preparar, uno por peticion.
PREPARAR_DIGEST_MAX_LOOPS=200

# UltraMsg (WhatsApp)
ULTRAMSG_INSTANCE_ID=<instance-id>
ULTRAMSG_TOKEN=<token>

# Webhook entrante de UltraMsg para valorar digests.
# Configura en UltraMsg una llamada POST a:
# https://ruralicos-api.onrender.com/webhooks/ultramsg/feedback?token=<este-token>
ULTRAMSG_WEBHOOK_TOKEN=<token-secreto-webhook>

# Si quieres responder con confirmacion por WhatsApp tras cada voto, pon true.
FEEDBACK_CONFIRMATION_ENABLED=false

# Muestra al final del digest una linea breve para valorar alertas con +1 -2.
DIGEST_FEEDBACK_ENABLED=true

# Autenticación
JWT_SECRET=<clave-secreta-larga-y-aleatoria>

# Token para proteger rutas de cron
CRON_TOKEN=<token-secreto-cron>

# Opcional: pepper especifico para hashear codigos temporales de verificacion.
# Si no se define, se usa JWT_SECRET como fallback.
VERIFICATION_CODE_PEPPER=<pepper-largo-y-aleatorio>

# Compatibilidad temporal: permite CRON_TOKEN en query (?token=...) en produccion.
# Recomendado: false. Usa header x-cron-token o Authorization: Bearer.
ALLOW_CRON_TOKEN_QUERY=false

# Servidor (opcional, por defecto 3000)
PORT=3000

# Modo digest: si es 'true' (o no se define), desactiva el envío por alerta individual
# y obliga a usar el flujo preparar-digest + enviar-digest.
DIGEST_ONLY_MODE=true

# Preclasificacion barata previa a la IA: off | observe | hard_exclusions.
# Empezar siempre en observe y medir antes de activar descartes duros.
ALERT_PRECLASSIFIER_MODE=observe

# Validacion final: shadow | critical | enforce.
# Mantener shadow durante la observacion inicial.
DIGEST_FINAL_VALIDATION_MODE=shadow

# Compatibilidad legacy. Solo se usa si DIGEST_FINAL_VALIDATION_MODE no esta definido.
DIGEST_FINAL_VALIDATION_ENFORCEMENT=false

# Delay en ms entre mensajes digest para evitar bloqueos anti-spam (por defecto 3000)
DIGEST_DELAY_MS=3000

# Envio del digest VIA COLA (patron outbox sobre mia_outbox): /alertas/enviar-digest
# encola en vez de mandar N WhatsApps en una request larga, y el drenador de
# /tareas/mia-outbox envia con reintentos+backoff (y delay anti-ban entre digests).
# Al activarlo, programa /tareas/mia-outbox cada ~5 min en la franja de envio para
# drenar la cola. default false = envio sincrono actual.
DIGEST_VIA_OUTBOX=false

# URL pública de la API (opcional, para generar enlaces)
PUBLIC_BASE_URL=https://ruralicos-api.onrender.com

# URL interna para autocalls del pipeline. Si no se define, el pipeline usa el
# host real de la peticion entrante. En Render puede fijarse al dominio onrender
# para no depender de un dominio custom/DNS.
# PIPELINE_INTERNAL_BASE_URL=https://ruralicos-api.onrender.com

# ─────────────────────────────────────────────
# Runner de pipeline con checkpoints (C1) — /tareas/pipeline-tick
# UN cron dispara el tick cada ~10 min; cada tick reclama el job del dia,
# avanza fases dentro de su presupuesto y el siguiente reanuda desde el
# checkpoint. Conviven con pipeline-diario hasta el cutover.
# ─────────────────────────────────────────────

# Sombra: true (DEFAULT, por seguridad durante el rollout) ejecuta toda la
# orquestacion SIN enviar WhatsApp ni escribir scraper_runs (pipeline_runs van
# como 'shadow:*'). Cutover real: PIPELINE_TICK_SHADOW=false (o ?shadow=false).
PIPELINE_TICK_SHADOW=true

# Presupuesto de tiempo por tick en ms, con margen frente al timeout de proxy:
# el tick para y hace checkpoint antes de agotarlo. (default 50000)
PIPELINE_TICK_BUDGET_MS=50000

# Timeout duro por request HTTP del tick (ms). Sin esto, una fuente que no
# responde cuelga el tick hasta que Render lo mata a los ~55s SIN checkpoint
# (job huerfano). Un timeout se registra como error y no tumba el dia. (default 20000)
PIPELINE_HTTP_TIMEOUT_MS=20000

# Reserva de presupuesto (ms): no se arranca una request nueva si no cabe entera
# antes del deadline. Por defecto coincide con PIPELINE_HTTP_TIMEOUT_MS para que
# ninguna llamada rebase el timeout de proxy de Render.
PIPELINE_TICK_RESERVE_MS=20000

# Antiguedad del heartbeat (ms) tras la que otro tick puede robar un claim
# colgado, y por debajo de la cual reset NO reabre un running vivo. Debe ser
# MENOR que el intervalo del cron (10 min) para recuperar dentro de la ventana,
# y mayor que la duracion de un tick sano. (default 300000 = 5 min)
PIPELINE_TICK_STALE_MS=300000

# Reintentos por fase antes de marcar el job como failed (el cron hace de
# backoff entre ticks). (default 3)
PIPELINE_STAGE_MAX_ATTEMPTS=3

# Timeout del preflight (ms): antes de crear/reclamar el job, el tick comprueba
# que baseUrl/health responde. Si no, devuelve 503 preflight_failed sin tocar
# nada (evita el self-fetch colgado contra un host que acepta y no responde).
# (default 5000)
PIPELINE_PREFLIGHT_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Observabilidad (opcional)
# ---------------------------------------------------------------------------

# DSN de Sentry para captura de errores 5xx y crashes de proceso. Sin definir,
# la captura queda desactivada y @sentry/node ni se carga (local/tests).
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ---------------------------------------------------------------------------
# Retencion de datos (cumplimiento, ver docs/CUMPLIMIENTO.md)
# ---------------------------------------------------------------------------

# Interruptor del borrado real en /tareas/retencion-datos. Con false (default),
# el endpoint SOLO informa (dry-run) aunque se pida dry_run=false.
RETENTION_ENABLED=false
