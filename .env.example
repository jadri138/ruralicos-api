# ─────────────────────────────────────────────
# RURALICOS API — Variables de entorno requeridas
# Copia este archivo a .env y rellena los valores.
# NUNCA subas .env a git.
# ─────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# OpenAI
OPENAI_API_KEY=sk-...

# UltraMsg (WhatsApp)
ULTRAMSG_INSTANCE_ID=<instance-id>
ULTRAMSG_TOKEN=<token>

# Autenticación
JWT_SECRET=<clave-secreta-larga-y-aleatoria>

# Token para proteger rutas de cron
CRON_TOKEN=<token-secreto-cron>

# Servidor (opcional, por defecto 3000)
PORT=3000

# Modo digest: si es 'true' (o no se define), desactiva el envío por alerta individual
# y obliga a usar el flujo preparar-digest + enviar-digest.
DIGEST_ONLY_MODE=true

# Delay en ms entre mensajes digest para evitar bloqueos anti-spam (por defecto 3000)
DIGEST_DELAY_MS=3000

# URL pública de la API (opcional, para generar enlaces)
PUBLIC_BASE_URL=https://api.ruralicos.es
